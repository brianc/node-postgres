{
  "compilerOptions": {
    "module": "node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "es2020",
    "noImplicitAny": true,
    "moduleResolution": "node16",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "./src",
    "incremental": true,
    "declaration": true,
    "paths": {
      "*": [
        "./node_modules/*",
        "./src/types/*"
      ]
    },
    "types": ["node"]
  },
  "include": [
    "src/**/*"
  ]
}
